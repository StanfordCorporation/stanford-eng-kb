# ─── Backend (Vercel function in prod, .env for local dev) ──────────────────

# Supabase Postgres. Use the POOLER endpoint in production (port 6543).
#   SUPABASE_DB_HOST=aws-0-<region>.pooler.supabase.com
#   SUPABASE_DB_PORT=6543
#   SUPABASE_DB_USER=postgres.<project-ref>
SUPABASE_DB_HOST=db.<project-ref>.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=<your-db-password>

# Embeddings — OpenAI text-embedding-3-small (384-dim, matches schema).
OPENAI_API_KEY=sk-...

# Chat answers — Anthropic Claude.
ANTHROPIC_API_KEY=sk-ant-...

# Shared secret guarding /api/ingest/upload. Generate a long random string.
# REQUIRED on Vercel — without it, /api/ingest/upload returns 503.
INGEST_TOKEN=<long-random-string>

# Optional: extra CORS origins for the backend (frontend on the same Vercel
# project is automatically same-origin and needs no entry here). Comma-
# separated. Localhost (any port) is always allowed for Vite dev.
# FRONTEND_ORIGIN=https://your-app.vercel.app

# ─── Bulk-upload CLI (local one-time seeding only) ──────────────────────────
# Used by `python -m backend.ingest.pipeline <folder> <org> <sub>`.
# API_URL=http://127.0.0.1:8000

# ─── Frontend (Vite, set on Vercel at build time) ───────────────────────────
# In a single-Vercel-project deploy, leave VITE_API_URL unset — /api/* is
# same-origin and Vercel rewrites route it to the Python function. Only set
# this if the backend lives on a different domain.
# VITE_API_URL=

# Mirrors INGEST_TOKEN; sent on uploads from the SPA. Bundled into the JS, so
# anyone who can load the page can read it. Acceptable behind Vercel password
# protection during soft launch; replace with a server-side proxy when adding
# real per-user auth.
# VITE_INGEST_TOKEN=<same as INGEST_TOKEN>
