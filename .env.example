# ─── Backend (Railway in prod, .env for local dev) ──────────────────────────

# Supabase Postgres. Use the POOLER endpoint in production (port 6543).
#   SUPABASE_DB_HOST=aws-0-<region>.pooler.supabase.com
#   SUPABASE_DB_PORT=6543
#   SUPABASE_DB_USER=postgres.<project-ref>
SUPABASE_DB_HOST=db.<project-ref>.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=<your-db-password>

# Claude
ANTHROPIC_API_KEY=sk-ant-...

# Production frontend origin(s) for CORS. Comma-separated for preview + prod.
# Localhost (any port) is always allowed for Vite dev.
# FRONTEND_ORIGIN=https://your-app.vercel.app

# Shared secret guarding /api/ingest/upload. Generate a long random string.
# REQUIRED on Railway — without it, /api/ingest/upload returns 503.
INGEST_TOKEN=<long-random-string>

# ─── Bulk-upload CLI (local one-time seeding only) ──────────────────────────
# Used by `python -m backend.ingest.pipeline <folder> <org> <sub>`.
# API_URL=http://127.0.0.1:8000

# ─── Frontend (Vite, set on Vercel at build time) ───────────────────────────
# Leave unset locally — Vite's proxy handles /api/* in dev. In prod, point at
# the Railway backend (no trailing slash).
# VITE_API_URL=https://<your-railway-url>
#
# Mirrors INGEST_TOKEN and is sent on uploads from the SPA. NOTE: this is
# bundled into the JS, so anyone who can load the page can read it. Acceptable
# behind Vercel password protection during soft launch; replace with a
# server-side proxy when adding real per-user auth.
# VITE_INGEST_TOKEN=<same as INGEST_TOKEN>
