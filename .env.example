# Supabase Postgres connection (use the Supavisor POOLER for serverless/Vercel)
# Dashboard: Project Settings -> Database -> Connection string -> "Session"/"Transaction"
# For Vercel, pooler endpoint is recommended:
#   SUPABASE_DB_HOST=aws-0-<region>.pooler.supabase.com
#   SUPABASE_DB_PORT=6543
#   SUPABASE_DB_USER=postgres.<project-ref>
SUPABASE_DB_HOST=db.<project-ref>.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=<your-db-password>

# LLM providers
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...   # only needed if you swap embedder.py to hosted embeddings

# Obsidian vault location (local ingest only — not needed at runtime)
VAULT_PATH=C:/Users/<you>/ObsidianVaults/EngKB

# Production frontend origin(s) for CORS, set on the backend (Railway).
# Comma-separated. Localhost (any port) is always allowed for Vite dev.
# FRONTEND_ORIGIN=https://your-app.vercel.app

# ─── Frontend (Vite) ────────────────────────────────────────────────────────
# Set on Vercel as a Build & Runtime env var. Leave unset locally — Vite's
# proxy handles /api/* in dev. In prod, point this at the Railway backend URL
# (no trailing slash), e.g. https://stanford-eng-kb.up.railway.app
# VITE_API_URL=
